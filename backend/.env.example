# =============================================================================
# Kids Pokédex - Backend Environment Configuration (Example)
# =============================================================================
# Copy this file to .env and fill in your actual values.
# Never commit .env to version control.

# --- App ---
PROJECT_NAME="Kids Pokédex"
VERSION="1.0.0"
API_V1_STR="/api/v1"



# --- Authentication ---
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your_secret_key_here
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# --- ADK / Gemini ---
# 1. DELETE or comment out the standard AI Studio key
# GOOGLE_API_KEY=your_google_api_key_here

# 2. Add your Google Cloud Project details
GOOGLE_CLOUD_PROJECT="gen-lang-client-0758468123"
GOOGLE_CLOUD_LOCATION="us-central1"
